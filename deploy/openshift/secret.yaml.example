# Example only — create real Secrets out-of-band (do not commit credentials).
#
# This file is documentation. It is NOT valid Kubernetes YAML and must NOT be
# applied with kubectl/oc apply. Use the oc create secret commands below instead.
#
# Connection names (SNOWFLAKE_CONNECTIONS, SNOWFLAKE_DEFAULT_CONNECTION) are
# non-secret and live in deploy/openshift/deployment.yaml.
#
# Each connection uses two Secrets:
#   1. *-config — loaded via envFrom; holds SNOWFLAKE_CONN_<NAME>_* literals
#      (including PRIVATE_KEY_FILE path, not the key material)
#   2. *-key — mounted as a volume at /etc/finops/snowflake/<connection>/
#      with a private_key file (never loaded into the process environment)
#
# SNOWFLAKE_CONN_<NAME>_PRIVATE_KEY_FILE must match the mounted file path.
#
# Preprod connection (default in deployment.yaml):
#
#   oc create secret generic finops-backend-snowflake-preprod-config \
#     --from-literal=SNOWFLAKE_CONN_PREPROD_ACCOUNT=example-preprod \
#     --from-literal=SNOWFLAKE_CONN_PREPROD_USER=svc-preprod \
#     --from-literal=SNOWFLAKE_CONN_PREPROD_WAREHOUSE=PREPROD_WH \
#     --from-literal=SNOWFLAKE_CONN_PREPROD_ROLE=PREPROD_ROLE \
#     --from-literal=SNOWFLAKE_CONN_PREPROD_DATABASE=PREPROD_DB \
#     --from-literal=SNOWFLAKE_CONN_PREPROD_SCHEMA=MARTS \
#     --from-literal=SNOWFLAKE_CONN_PREPROD_PRIVATE_KEY_FILE=/etc/finops/snowflake/preprod/private_key \
#     -n finops-team--finops-tools-backend
#
#   oc create secret generic finops-backend-snowflake-preprod-key \
#     --from-file=private_key=./preprod_rsa_key.p8 \
#     -n finops-team--finops-tools-backend
#
# Sandbox connection:
#
#   oc create secret generic finops-backend-snowflake-sandbox-config \
#     --from-literal=SNOWFLAKE_CONN_SANDBOX_ACCOUNT=example-sandbox \
#     --from-literal=SNOWFLAKE_CONN_SANDBOX_USER=svc-sandbox \
#     --from-literal=SNOWFLAKE_CONN_SANDBOX_WAREHOUSE=SANDBOX_WH \
#     --from-literal=SNOWFLAKE_CONN_SANDBOX_ROLE=SANDBOX_ROLE \
#     --from-literal=SNOWFLAKE_CONN_SANDBOX_DATABASE=SANDBOX_DB \
#     --from-literal=SNOWFLAKE_CONN_SANDBOX_SCHEMA=SANDBOX_SCHEMA \
#     --from-literal=SNOWFLAKE_CONN_SANDBOX_PRIVATE_KEY_FILE=/etc/finops/snowflake/sandbox/private_key \
#     -n finops-team--finops-tools-backend
#
#   oc create secret generic finops-backend-snowflake-sandbox-key \
#     --from-file=private_key=./sandbox_rsa_key.p8 \
#     -n finops-team--finops-tools-backend
#
# To update an existing Secret, append --dry-run=client -o yaml | oc apply -f -
# to the command above. Restart the Deployment after changing credentials:
#
#   oc rollout restart deployment/finops-backend -n finops-team--finops-tools-backend

{% extends "base.html.j2" %}

{% block title %}Costs Report — {{ account_summary }}{% endblock %}

{% block content %}
<header>
  <h1>Costs Report</h1>
  <p class="meta">
    <strong>Accounts:</strong> {{ account_summary }}<br>
    <strong>Period:</strong> {{ start_date }} — {{ end_date }}<br>
    <strong>Generated:</strong> {{ generated_at }}
  </p>
</header>

<section>
  <h2>Total costs</h2>
  <p class="meta">{{ metric }} (net amortized)</p>
  <p class="total-amount">{{ total_formatted }}</p>
</section>

<section>
  <h2>Costs per linked account</h2>
  {% if by_account %}
  <table>
    <thead>
      <tr>
        <th>Account</th>
        <th class="amount">Amount</th>
        <th class="percent">Share</th>
      </tr>
    </thead>
    <tbody>
      {% for row in by_account %}
      <tr>
        <td>{{ row.Label }}</td>
        <td class="amount">{{ row.AmountFormatted }}</td>
        <td class="percent">{{ row.PercentFormatted }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="meta">No linked account breakdown available for this scope.</p>
  {% endif %}
</section>

<section>
  <h2>Costs per service</h2>
  {% if by_service %}
  <table>
    <thead>
      <tr>
        <th>Service</th>
        <th class="amount">Amount</th>
        <th class="percent">Share</th>
      </tr>
    </thead>
    <tbody>
      {% for row in by_service %}
      <tr>
        <td>{{ row.Label }}</td>
        <td class="amount">{{ row.AmountFormatted }}</td>
        <td class="percent">{{ row.PercentFormatted }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="meta">No service breakdown available.</p>
  {% endif %}
</section>

<section>
  <h2>Daily costs</h2>
  <div class="chart-wrap">
    {{ daily_chart_svg | safe }}
  </div>
</section>
{% endblock %}
